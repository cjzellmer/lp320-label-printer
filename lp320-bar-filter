#!/usr/bin/env python3
"""CUPS filter for HPRT LP320 thermal label printer.

Converts PDF/PostScript/image input to TSPL BAR commands. The LP320 uses
a USB-to-parallel bridge chip (ICS Advent 0FE6:811E) that corrupts binary
data, so BITMAP commands cannot be used. Instead we rasterize input to a
monochrome image and emit pure ASCII BAR commands for each rectangular
black region.

CUPS filter interface:
    filter job-id user title copies options [filename]
    If filename is omitted, read from stdin.
"""

import datetime
import io
import os
import subprocess
import sys
import tempfile
import traceback

from PIL import Image, ImageChops

DPI = 203
DEFAULT_WIDTH_MM = 101.6   # 4 inches
DEFAULT_HEIGHT_MM = 152.4  # 6 inches
GAP_MM = 3
MARGIN_DOTS = int(0.125 * DPI)  # 1/8 inch margin on all sides


def mm_to_dots(mm):
    return int(mm * DPI / 25.4)


def parse_page_size_from_options(options_str):
    """Extract page size from CUPS options string.

    Handles CUPS wNNNhNNN format and macOS NNNxNNNmm format.
    """
    width_mm = DEFAULT_WIDTH_MM
    height_mm = DEFAULT_HEIGHT_MM

    for opt in options_str.split():
        for prefix in ('media=', 'PageSize='):
            if opt.startswith(prefix):
                val = opt[len(prefix):]
                # CUPS format: wNNNhNNN (values in mm)
                if val.startswith('w') and 'h' in val:
                    try:
                        parts = val[1:].split('h')
                        width_mm = float(parts[0])
                        height_mm = float(parts[1])
                    except (ValueError, IndexError):
                        pass
                # macOS format: NNNxNNNmm
                elif 'x' in val:
                    try:
                        clean = val.lower().rstrip('m')
                        parts = clean.split('x')
                        width_mm = float(parts[0])
                        height_mm = float(parts[1])
                    except (ValueError, IndexError):
                        pass
    return width_mm, height_mm


def parse_darkness_from_options(options_str):
    """Extract print darkness setting (range 5-15)."""
    for opt in options_str.split():
        if opt.startswith('PrintDarkness='):
            try:
                return int(opt.split('=')[1])
            except (ValueError, IndexError):
                pass
    return 12


def parse_speed_from_options(options_str):
    """Extract print speed setting (range 2-6 in/sec)."""
    for opt in options_str.split():
        if opt.startswith('PrintSpeed='):
            try:
                val = opt.split('=')[1]
                if val != 'None':
                    return int(val)
            except (ValueError, IndexError):
                pass
    return 4


def _rasterize_pdf(pdf_path, width_dots, height_dots):
    """Rasterize a PDF to grayscale PIL Image using pdftoppm."""
    with tempfile.TemporaryDirectory() as tmpdir:
        out_prefix = os.path.join(tmpdir, 'page')
        subprocess.run([
            'pdftoppm',
            '-gray',           # grayscale (no dithering)
            '-r', str(DPI),    # resolution
            '-singlefile',     # only first page
            pdf_path,
            out_prefix
        ], check=True, stderr=subprocess.PIPE)

        pgm_path = out_prefix + '.pgm'
        if not os.path.exists(pgm_path):
            for ext in ('.png', '.ppm', '.pbm'):
                alt = out_prefix + ext
                if os.path.exists(alt):
                    pgm_path = alt
                    break

        return Image.open(pgm_path).convert('L')


def _rasterize_ps(ps_path, width_dots, height_dots):
    """Rasterize PostScript to grayscale PIL Image using Ghostscript.

    Renders at the document's native page size so content from oversized
    pages (e.g. Letter-sized PS from macOS "Generic PostScript Printer")
    is captured at full resolution. The caller's auto-crop + scale logic
    then fits the actual content to the label.
    """
    with tempfile.TemporaryDirectory() as tmpdir:
        out_path = os.path.join(tmpdir, 'page.png')
        subprocess.run([
            'gs', '-q', '-dNOPAUSE', '-dBATCH', '-dSAFER',
            '-sDEVICE=pnggray',
            '-r' + str(DPI),
            '-sOutputFile=' + out_path,
            ps_path
        ], check=True, stderr=subprocess.PIPE)

        return Image.open(out_path).convert('L')


def file_to_image(file_path, width_dots, height_dots):
    """Convert input file to a monochrome PIL Image at label dimensions.

    Supports PDF, PostScript, and image files (PNG, JPEG, etc.).
    Uses grayscale rasterization with hard threshold for clean BAR merging.
    """
    with open(file_path, 'rb') as f:
        header = f.read(16)

    img = None

    if header.startswith(b'%!') and not header.startswith(b'%PDF'):
        sys.stderr.write("INFO: PostScript input, rasterizing with Ghostscript\n")
        img = _rasterize_ps(file_path, width_dots, height_dots)
    elif header.startswith(b'%PDF'):
        sys.stderr.write("INFO: PDF input, rasterizing with pdftoppm\n")
        img = _rasterize_pdf(file_path, width_dots, height_dots)

    if img is None:
        try:
            img = Image.open(file_path)
            img.load()
            img = img.convert('L')
            sys.stderr.write(f"INFO: Image input: {img.size}\n")
        except Exception:
            sys.stderr.write("INFO: Unknown format, trying as PDF\n")
            img = _rasterize_pdf(file_path, width_dots, height_dots)

    # Auto-crop whitespace margins from the source image
    inverted = ImageChops.invert(img)
    bbox = inverted.getbbox()
    if bbox:
        img = img.crop(bbox)

    # Scale to fill printable area (label minus margins), maintain aspect ratio
    printable_w = width_dots - 2 * MARGIN_DOTS
    printable_h = height_dots - 2 * MARGIN_DOTS
    img_w, img_h = img.size
    scale = min(printable_w / img_w, printable_h / img_h)
    new_w = int(img_w * scale)
    new_h = int(img_h * scale)
    if (new_w, new_h) != (img_w, img_h):
        img = img.resize((new_w, new_h), Image.LANCZOS)

    # Center on white canvas at exact label dimensions (margins are built in)
    canvas = Image.new('L', (width_dots, height_dots), 255)
    paste_x = MARGIN_DOTS + (printable_w - img.size[0]) // 2
    paste_y = MARGIN_DOTS + (printable_h - img.size[1]) // 2
    canvas.paste(img, (paste_x, paste_y))

    # Hard threshold: < 128 = black (0), >= 128 = white (255)
    return canvas.point(lambda p: 0 if p < 128 else 255, mode='1')


def image_to_bar_commands(img):
    """Convert monochrome image to TSPL BAR commands.

    Scans each row for contiguous runs of black pixels, then merges
    identical runs across consecutive rows into rectangles to minimize
    the number of commands.

    In PIL mode '1': pixel value 0 = black.
    """
    width, height = img.size
    pixels = img.load()
    commands = []

    # Track active runs for vertical merging
    # Key: (x_start, run_width) -> (y_start, rect_height)
    active_runs = {}

    for y in range(height):
        row_runs = set()
        x = 0
        while x < width:
            if pixels[x, y] != 0:
                x += 1
                continue
            x_start = x
            while x < width and pixels[x, y] == 0:
                x += 1
            row_runs.add((x_start, x - x_start))

        # Flush runs that ended (not in this row)
        for key in set(active_runs.keys()) - row_runs:
            y_start, h = active_runs.pop(key)
            commands.append(f"BAR {key[0]},{y_start},{key[1]},{h}")

        # Extend continuing runs
        for key in set(active_runs.keys()) & row_runs:
            y_start, h = active_runs[key]
            active_runs[key] = (y_start, h + 1)

        # Start new runs
        for key in row_runs - set(active_runs.keys()):
            active_runs[key] = (y, 1)

    # Flush remaining runs
    for (x_start, w), (y_start, h) in active_runs.items():
        commands.append(f"BAR {x_start},{y_start},{w},{h}")

    return commands


def main():
    if len(sys.argv) < 6:
        sys.stderr.write("Usage: lp320-bar-filter job-id user title copies options [filename]\n")
        sys.exit(1)

    job_id = sys.argv[1]
    user = sys.argv[2]
    title = sys.argv[3]
    copies = int(sys.argv[4])
    options = sys.argv[5]
    input_file = sys.argv[6] if len(sys.argv) > 6 else None

    try:
        logfile = open('/tmp/lp320-filter.log', 'a')
    except OSError:
        logfile = None

    def log(msg):
        if logfile:
            try:
                logfile.write(f"{datetime.datetime.now()} {msg}\n")
                logfile.flush()
            except OSError:
                pass
        sys.stderr.write(f"INFO: {msg}\n")

    log(f"Job {job_id}: {title} for {user}")

    width_mm, height_mm = parse_page_size_from_options(options)
    darkness = parse_darkness_from_options(options)
    speed = parse_speed_from_options(options)

    width_dots = mm_to_dots(width_mm)
    height_dots = mm_to_dots(height_mm)

    log(f"Label: {width_mm}x{height_mm}mm ({width_dots}x{height_dots} dots), "
        f"darkness={darkness}, speed={speed}")

    if input_file is None:
        with tempfile.NamedTemporaryFile(suffix='.dat', delete=False) as tmp:
            data = sys.stdin.buffer.read()
            tmp.write(data)
            input_file = tmp.name
            cleanup_input = True
            log(f"Read {len(data)} bytes from stdin")
    else:
        cleanup_input = False

    try:
        img = file_to_image(input_file, width_dots, height_dots)
        log(f"Rasterized: {img.size}")

        # Auto-detect inverted images (>50% black = probably inverted)
        pixels = img.load()
        w, h = img.size
        black_count = sum(
            1 for y in range(0, h, 10) for x in range(0, w, 10)
            if pixels[x, y] == 0
        )
        total_sampled = (w // 10) * (h // 10)
        if total_sampled > 0 and black_count / total_sampled > 0.5:
            log("Image appears inverted, flipping")
            img = ImageChops.invert(img)

        bar_commands = image_to_bar_commands(img)
        log(f"Generated {len(bar_commands)} BAR commands")

        # Build TSPL output
        output = [
            f"SIZE {width_mm} mm, {height_mm} mm",
            f"GAP {GAP_MM} mm, 0 mm",
            f"SPEED {speed}",
            f"DENSITY {darkness}",
            "DIRECTION 1",
            "CLS",
        ]
        output.extend(bar_commands)
        output.append(f"PRINT {copies}")
        output.append("")

        tspl_data = "\r\n".join(output)
        sys.stdout.buffer.write(tspl_data.encode('ascii'))
        sys.stdout.buffer.flush()

        log(f"Done: {len(tspl_data)} bytes, {len(bar_commands)} BAR commands")

    except Exception as e:
        log(f"ERROR: {e}")
        log(traceback.format_exc())
        raise

    finally:
        if cleanup_input:
            os.unlink(input_file)
        if logfile:
            logfile.close()


def test_direct(file_path, device='/dev/usb/lp0'):
    """Send a file directly to the printer, bypassing CUPS."""
    sys.argv = ['lp320-bar-filter', '0', 'test', 'test', '1',
                'media=w100h150 PrintDarkness=12', file_path]

    old_stdout = sys.stdout
    buf = io.BytesIO()
    sys.stdout = io.TextIOWrapper(buf, encoding='ascii')

    main()

    buf.seek(0)
    data = buf.read()
    sys.stdout = old_stdout

    sys.stderr.write(f"Writing {len(data)} bytes to {device}\n")
    with open(device, 'wb') as f:
        f.write(data)
    sys.stderr.write("Done.\n")


if __name__ == '__main__':
    if len(sys.argv) >= 2 and sys.argv[1] == '--test-direct':
        if len(sys.argv) < 3:
            print("Usage: lp320-bar-filter --test-direct <file> [/dev/usb/lp0]")
            sys.exit(1)
        dev = sys.argv[3] if len(sys.argv) > 3 else '/dev/usb/lp0'
        test_direct(sys.argv[2], dev)
    else:
        main()
